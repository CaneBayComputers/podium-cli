# Get current project name (directory basename)
get_project_name() {
    basename "$(pwd)"
}

# Validate that we're in a Podium project directory and it's running
validate_project_context() {
    # Check if docker-compose.yaml exists
    if [ ! -f "docker-compose.yaml" ]; then
        echo-red "❌ Not in a Podium project directory!"
        echo-white "Current directory: $(pwd)"
        echo-white "Expected: docker-compose.yaml file"
        echo-return
        echo-cyan "💡 Solutions:"
        echo "  • Navigate to a project directory: cd \$(podium projects-dir)/your-project"
        echo "  • Create a new project: podium new"
        echo "  • List existing projects: ls \$(podium projects-dir)"
        return 1
    fi
    
    # Check if it's actually a Podium project by looking for the Podium VPC network
    if ! grep -q "podium-cli_vpc" docker-compose.yaml 2>/dev/null; then
        echo-red "❌ Not a Podium project!"
        echo-white "Found docker-compose.yaml but it's not a Podium project."
        echo-white "Current directory: $(pwd)"
        echo-return
        echo-cyan "💡 Solutions:"
        echo "  • Navigate to a Podium project directory"
        echo "  • Convert this to a Podium project: podium setup $(basename \"$(pwd)\")"
        return 1
    fi
    
    # Get container name from docker-compose.yaml
    local container_name=$(grep "container_name:" docker-compose.yaml | head -1 | sed 's/.*container_name: *\(.*\)/\1/')
    
    if [ -z "$container_name" ]; then
        echo-red "❌ Invalid docker-compose.yaml!"
        echo-white "Could not find container_name in docker-compose.yaml"
        return 1
    fi
    
    # Check if container is running
    if ! docker ps --format "{{.Names}}" | grep -q "^${container_name}$"; then
        echo-red "❌ Project not running!"
        echo-white "Project: $(basename \"$(pwd)\")"
        echo-white "Container: $container_name"
        echo-white "Status: Stopped"
        echo-return
        echo-cyan "💡 Solutions:"
        echo "  • Start the project: podium up"
        echo "  • Check project status: podium status"
        echo "  • View all projects: podium status"
        return 1
    fi
    
    # All checks passed
    return 0
}

# Docker exec helper
docker_exec() {
    local user="$1"
    shift
    local project_name="$(get_project_name)"
    # Wrap single quoted compound commands through bash so agents can pass
    # "python3 manage.py foo" as one string without OCI exec errors
    if [ $# -eq 1 ] && [[ "$1" == *" "* ]]; then
        set -- bash -c "$1"
    fi
    local tty_flags="-it"
    [ -t 0 ] || tty_flags="-i"
    if [ "$user" = "root" ]; then
        docker container exec $tty_flags --user root -w /usr/share/nginx/html "$project_name" "$@"
    else
        docker container exec $tty_flags --user "$(id -u):$(id -g)" -w /usr/share/nginx/html "$project_name" "$@"
    fi
}

# Docker exec helper without TTY (for automation/CI)
docker_exec_notty() {
    local user="$1"
    shift
    local project_name="$(get_project_name)"
    # Wrap single quoted compound commands through bash so agents can pass
    # "python3 manage.py foo" as one string without OCI exec errors
    if [ $# -eq 1 ] && [[ "$1" == *" "* ]]; then
        set -- bash -c "$1"
    fi
    if [ "$user" = "root" ]; then
        docker container exec -i --user root -w /usr/share/nginx/html "$project_name" "$@"
    else
        docker container exec -i --user "$(id -u):$(id -g)" -w /usr/share/nginx/html "$project_name" "$@"
    fi
}

# Detect project framework from files present in the current directory
detect_project_framework() {
    if [ -f "artisan" ]; then
        echo "laravel"
    elif [ -f "manage.py" ]; then
        echo "django"
    elif [ -f "package.json" ]; then
        if grep -q '"@nestjs/core"' package.json 2>/dev/null; then
            echo "nestjs"
        else
            echo "node"
        fi
    elif [ -f "requirements.txt" ] || [ -f "main.py" ] || [ -f "app.py" ]; then
        echo "python"
    elif [ -f "composer.json" ]; then
        echo "php"
    else
        echo "unknown"
    fi
}

# Main command dispatcher
case "$1" in
    # Containerized development tools
    "composer")
        validate_project_context || exit 1
        shift
        docker_exec developer composer -d /usr/share/nginx/html "$@"
        ;;
    "art"|"artisan")
        validate_project_context || exit 1
        shift
        docker_exec developer php /usr/share/nginx/html/artisan "$@"
        ;;
    "wp")
        validate_project_context || exit 1
        shift
        docker_exec developer wp "$@"
        ;;
    "php")
        validate_project_context || exit 1
        shift
        docker_exec developer php "$@"
        ;;
    "npm")
        validate_project_context || exit 1
        shift
        docker_exec_notty developer npm "$@"
        ;;
    "npx")
        validate_project_context || exit 1
        shift
        docker_exec_notty developer npx "$@"
        ;;
    "node")
        validate_project_context || exit 1
        shift
        docker_exec developer node "$@"
        ;;
    "python"|"python3")
        validate_project_context || exit 1
        shift
        docker_exec developer python3 "$@"
        ;;
    "pip"|"pip3")
        validate_project_context || exit 1
        shift
        if [[ "$1" == "install" ]]; then
            shift
            docker_exec_notty developer pip3 install --break-system-packages "$@"
        else
            docker_exec_notty developer pip3 "$@"
        fi
        ;;
    "shell")
        validate_project_context || exit 1
        local _framework
        _framework=$(detect_project_framework)
        case "$_framework" in
            "laravel")
                docker_exec developer php /usr/share/nginx/html/artisan tinker
                ;;
            "django")
                docker_exec developer python3 /usr/share/nginx/html/manage.py shell
                ;;
            "nestjs")
                if [ -f "src/repl.ts" ]; then
                    docker_exec developer npm run start -- --entryFile repl
                else
                    docker_exec developer node
                fi
                ;;
            "node")
                docker_exec developer node
                ;;
            "python")
                docker_exec developer python3
                ;;
            *)
                echo-yellow "Could not detect framework. Opening bash shell."
                docker_exec developer bash
                ;;
        esac
        ;;
    "django")
        validate_project_context || exit 1
        shift
        case "$1" in
            "manage")
                if [ ! -f "manage.py" ]; then
                    echo-red "No manage.py found. Are you in a Django project directory?"
                    exit 1
                fi
                shift
                docker_exec_notty developer python3 /usr/share/nginx/html/manage.py "$@"
                ;;
            "shell")
                if [ ! -f "manage.py" ]; then
                    echo-red "No manage.py found. Are you in a Django project directory?"
                    exit 1
                fi
                docker_exec developer python3 /usr/share/nginx/html/manage.py shell
                ;;
            "")
                echo-yellow "Usage: podium django <subcommand>"
                echo "  podium django manage <args>  - Run manage.py with arguments"
                echo "  podium django shell          - Open Django interactive shell"
                exit 1
                ;;
            *)
                echo-red "Unknown django subcommand: $1"
                echo "  podium django manage <args>  - Run manage.py with arguments"
                echo "  podium django shell          - Open Django interactive shell"
                exit 1
                ;;
        esac
        ;;
    "phpcs")
        validate_project_context || exit 1
        shift
        # Auto-attach default ruleset if none provided
        has_standard=false
        for arg in "$@"; do
            case "$arg" in
                --standard=*|--standard)
                    has_standard=true
                    break
                    ;;
            esac
        done
        if [ "$has_standard" = false ]; then
            set -- --standard="/etc/phpcs-ruleset.xml" "$@"
        fi
        docker_exec developer phpcs "$@"
        ;;
    "phpcbf")
        validate_project_context || exit 1
        shift
        # Auto-attach default ruleset if none provided
        has_standard=false
        for arg in "$@"; do
            case "$arg" in
                --standard=*|--standard)
                    has_standard=true
                    break
                    ;;
            esac
        done
        if [ "$has_standard" = false ]; then
            set -- --standard="/etc/phpcs-ruleset.xml" "$@"
        fi
        docker_exec developer phpcbf "$@"
        ;;
    "phpmd")
        validate_project_context || exit 1
        shift
        # Auto-attach default format and ruleset if only a path is provided
        if [ "$#" -eq 1 ]; then
            set -- "$1" text "/etc/phpmd.xml"
        fi
        docker_exec developer phpmd "$@"
        ;;
    
    # Container execution
    "exec")
        validate_project_context || exit 1
        shift
        docker_exec_notty developer "$@"
        ;;
    "exec-root")
        validate_project_context || exit 1
        shift
        docker_exec_notty root "$@"
        ;;
    "exec-tty")
        validate_project_context || exit 1
        shift
        docker_exec developer "$@"
        ;;
    "exec-tty-root")
        validate_project_context || exit 1
        shift
        docker_exec root "$@"
        ;;
    "bash")
        validate_project_context || exit 1
        shift
        docker_exec developer bash "$@"
        ;;
    "tinker")
        validate_project_context || exit 1
        shift
        docker_exec developer php /usr/share/nginx/html/artisan tinker "$@"
        ;;
    
    # Enhanced Laravel commands
    "db-refresh")
        validate_project_context || exit 1
        echo-yellow "Refreshing database..."
        docker_exec developer php /usr/share/nginx/html/artisan migrate:fresh
        docker_exec developer php /usr/share/nginx/html/artisan db:seed
        echo-green "Database refreshed!"
        ;;
    "cache-refresh")
        validate_project_context || exit 1
        echo-yellow "Clearing Laravel caches..."
        docker_exec developer php /usr/share/nginx/html/artisan cache:clear
        docker_exec developer php /usr/share/nginx/html/artisan route:clear
        docker_exec developer php /usr/share/nginx/html/artisan config:clear
        docker_exec developer composer -d /usr/share/nginx/html dump-autoload
        echo-green "Caches cleared!"
        ;;
    
    # Service management
    "mysql")
        shift
        if [ -t 0 ]; then
            docker container exec -it "$MARIADB_CONTAINER_NAME" mariadb -u"root" "$@"
        else
            docker container exec -i "$MARIADB_CONTAINER_NAME" mariadb -u"root" "$@"
        fi
        ;;
    "redis")
        shift
        docker container exec -it "$REDIS_CONTAINER_NAME" redis-cli "$@"
        ;;
    "redis-flush")
        docker container exec -it "$REDIS_CONTAINER_NAME" redis-cli FLUSHALL
        echo-green "Redis flushed!"
        ;;
    "memcache")
        shift
        if [ $# -eq 0 ]; then
            echo-yellow "Available Memcached commands:"
            echo "  stats           - Show server statistics"
            echo "  version         - Show server version"
            echo "  flush_all       - Flush all cached items"
            echo "  get <key>       - Get value for key"
            echo "  set <key> <val> - Set key to value"
            echo
            echo-white "Usage: podium memcache <command>"
            echo-white "Example: podium memcache stats"
        else
            echo "$@" | docker container exec -i memcached nc localhost 11211
        fi
        ;;
    "memcache-flush")
        echo "flush_all" | docker container exec -i memcached nc localhost 11211
        echo-green "Memcached flushed!"
        ;;
    "memcache-stats")
        echo "stats" | docker container exec -i memcached nc localhost 11211
        ;;
    "supervisor")
        validate_project_context || exit 1
        shift
        project_name="$(get_project_name)"
        if [ $# -eq 0 ]; then
            echo-yellow "Available supervisorctl commands:"
            echo "  status          - Show process status"
            echo "  start <name>    - Start a process"
            echo "  stop <name>     - Stop a process"
            echo "  restart <name>  - Restart a process"
            echo "  reload          - Reload configuration"
            echo "  reread          - Reread configuration files"
            echo
            echo-white "Usage: podium supervisor <command>"
            echo-white "Example: podium supervisor status"
        else
            docker container exec -i "$project_name" supervisorctl "$@"
        fi
        ;;
    "supervisor-status")
        validate_project_context || exit 1
        project_name="$(get_project_name)"
        echo-cyan "Supervisor status in container: $project_name"
        docker container exec -i "$project_name" supervisorctl status
        ;;
    
    # Project management
    "up")
        (
            cd "$(get_projects_dir)"
            if [ -n "$2" ]; then
                "$SCRIPT_DIR/scripts/startup.sh" "$2"
            else
                "$SCRIPT_DIR/scripts/startup.sh"
            fi
        )
        ;;
    "down")
        (
            cd "$(get_projects_dir)"
            if [ -n "$2" ]; then
                "$SCRIPT_DIR/scripts/shutdown.sh" "$2"
            else
                "$SCRIPT_DIR/scripts/shutdown.sh"
            fi
        )
        ;;
    "status")
        (
            cd "$(get_projects_dir)"
            if [ -n "$2" ]; then
                "$SCRIPT_DIR/scripts/status.sh" "$2"
            else
                "$SCRIPT_DIR/scripts/status.sh"
            fi
        )
        ;;
    "new")
        "$SCRIPT_DIR/scripts/new_project.sh" "${@:2}"
        ;;
    "create")
        "$SCRIPT_DIR/scripts/create.sh" "${@:2}"
        ;;
    "install")
        "$SCRIPT_DIR/scripts/install.sh" "${@:2}"
        ;;
    "clone")
        if [ -z "$2" ]; then
            echo-red "Usage: podium clone <repository-url> [project-name] [options]"
            echo-white "Options: --overwrite-docker-compose, --no-github, --framework NAME, --no-startup"
            exit 1
        fi
        "$SCRIPT_DIR/scripts/clone_project.sh" "${@:2}"
        ;;
    "setup")
        if [ -z "$2" ]; then
            echo-red "Usage: podium setup <project-name> [database-engine] [display-name] [description] [emoji] [options]"
            echo-white "Sets up an existing project directory as a Podium project"
            exit 1
        fi
        "$SCRIPT_DIR/scripts/setup_project.sh" "${@:2}"
        ;;
    "remove")
        if [ -z "$2" ]; then
            echo-red "Usage: podium remove <project-name> [options]"
            echo-white "Options: --force-trash-project, --force-db-delete, --force"
            exit 1
        fi
        "$SCRIPT_DIR/scripts/remove_project.sh" "${@:2}"
        ;;
    
    # System management
    "configure")
        "$SCRIPT_DIR/scripts/configure.sh" "${@:2}"
        ;;
    "resume")
        "$SCRIPT_DIR/scripts/resume.sh" "${@:2}"
        ;;
    "ai")
        "$SCRIPT_DIR/scripts/ai.sh" "${@:2}"
        ;;
    "ai-set")
        "$SCRIPT_DIR/scripts/ai_set.sh" "${@:2}"
        ;;
    "update")
        "$SCRIPT_DIR/scripts/update.sh" "${@:2}"
        ;;
    "start-services")
        "$SCRIPT_DIR/scripts/start_services.sh"
        ;;
    "stop-services")
        "$SCRIPT_DIR/scripts/stop_services.sh"
        ;;
    "uninstall")
        "$SCRIPT_DIR/scripts/uninstall.sh" "${@:2}"
        ;;
    "projects-dir")
        # Helper command to show projects directory path
        echo "$(get_projects_dir)"
        ;;
    
    # Help and default
    "help"|"-h"|"--help"|"")
        show_help
        ;;
    *)
