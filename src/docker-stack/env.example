# Podium Environment Configuration
# This file is copied to .env during installation and contains
# configuration shared across all Podium scripts and Docker services

# Network configuration (auto-generated during install)
#VPC_SUBNET=10.123.45

# Projects directory - where your development projects are stored
# Default: ~/podium-projects (can be customized)
#PROJECTS_DIR=~/podium-projects

# Default Kavera repository for `podium create`
# Uncomment one of the following lines or set your own:
#KAVERA_REPOSITORY_URL=https://github.com/CaneBayComputers/kavera.git
#KAVERA_REPOSITORY_URL=git@github.com:CaneBayComputers/kavera.git
